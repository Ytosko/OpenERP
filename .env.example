# Supabase Credentials (safe to expose in the client bundle — access is
# controlled by Row Level Security policies, not by hiding the anon key)
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# App URL
VITE_APP_URL=http://localhost:3000

# NOTE: The Gemini API key is NO LONGER a client-side variable. It lives as a
# server secret on the ai-gateway Supabase Edge Function:
#   supabase functions deploy ai-gateway
#   supabase secrets set GEMINI_API_KEY=your-key
